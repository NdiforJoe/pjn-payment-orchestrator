{
  "name": "pjn-payment-orchestrator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc --project cdk/tsconfig.json && tsc --project src/tsconfig.json",
    "build:cdk": "tsc --project cdk/tsconfig.json",
    "build:src": "tsc --project src/tsconfig.json",
    "cdk": "cdk",
    "synth": "cd cdk && npx cdk synth",
    "deploy:staging": "cd cdk && npx cdk deploy --all -c env=staging",
    "deploy:prod": "cd cdk && npx cdk deploy --all -c env=prod --require-approval broadening",
    "test": "jest",
    "lint": "eslint 'src/**/*.ts' 'cdk/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'cdk/**/*.ts'"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-sfn": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@aws-sdk/client-eventbridge": "^3.600.0",
    "aws-xray-sdk": "^3.12.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.140",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "aws-cdk": "^2.147.0",
    "aws-cdk-lib": "^2.147.0",
    "constructs": "^10.3.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.57.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  }
}
